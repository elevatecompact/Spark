# Spark Platform - Local Development Environment
SPARK_ENVIRONMENT=development
SPARK_LOG_LEVEL=debug

# PostgreSQL
SPARK_DATABASE_URL=postgres://spark:spark_dev@localhost:5432/spark?sslmode=disable

# Redis
SPARK_REDIS_URL=redis://localhost:6379/0

# Kafka
SPARK_KAFKA_BROKERS=localhost:9092

# JWT
SPARK_JWT_SECRET=spark-dev-jwt-secret-do-not-use-in-production
SPARK_JWT_EXPIRY=24h

# Server
SPARK_SERVER_PORT=8080
SPARK_GRPC_PORT=9090

# CORS
SPARK_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# OAuth
SPARK_OAUTH_CLIENT_ID=spark-web
SPARK_OAUTH_CLIENT_SECRET=spark-web-secret

# Passkeys
SPARK_PASSKEY_RPID=localhost
SPARK_PASSKEY_RP_NAME=Spark
SPARK_PASSKEY_ORIGIN=http://localhost:3000

# OpenTelemetry
SPARK_OTEL_ENDPOINT=http://localhost:4318

# Sentry (optional)
# SPARK_SENTRY_DSN=
